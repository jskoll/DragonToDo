      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#D08770"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#4E9F58"
      }
    },
    {
      "scope": [
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#E6E8E3"
      }
    },
    {
      "scope": [
        "meta.import",
        "meta.export"
      ],
      "settings": {
        "foreground": "#8FBCBB"
      }
    },
    {
      "scope": [
        "meta.jsx.children",
        "meta.tag.tsx",
        "meta.tag.jsx"
      ],
      "settings": {
        "foreground": "#E6E8E3"
      }
    }
  ]
